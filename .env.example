# LLM Provider Configuration
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git — it contains your API key.

# Provider: anthropic | openai | google | custom
VITE_LLM_PROVIDER=anthropic

# Your API key for the chosen provider
VITE_LLM_API_KEY=

# Model to use (optional — uses provider default if empty)
# Anthropic: claude-sonnet-4-6, claude-haiku-4-5-20251001
# OpenAI: gpt-4o, gpt-4o-mini
# Google: gemini-2.0-flash-lite, gemini-1.5-flash
# Custom: whatever your endpoint expects
VITE_LLM_MODEL=

# Base URL for custom/self-hosted providers (e.g. http://localhost:11434/v1 for Ollama)
# Leave empty for standard providers
VITE_LLM_BASE_URL=
