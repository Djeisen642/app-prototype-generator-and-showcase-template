{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "types": ["vitest/globals", "node"]
  },
  "include": [".astro/types.d.ts", "src", "scripts", "*.config.mjs"],
  "exclude": ["dist", "node_modules"]
}
