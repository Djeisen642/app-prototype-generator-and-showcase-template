---
import type { Prototype } from "../types";
import { statusStyle } from "../lib/status";

interface Props {
  prototype: Prototype;
}

const { prototype } = Astro.props;
const firstImage = prototype.images[0];
---

<a
  href={`/showcase/${prototype.id}`}
  class="group block bg-slate-800 rounded-xl overflow-hidden border border-slate-700 hover:border-slate-500 transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-black/30"
>
  <div class="h-48 overflow-hidden bg-slate-700">
    {
      firstImage ? (
        <img
          src={firstImage}
          alt=""
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        />
      ) : (
        <div class="w-full h-full flex flex-col items-center justify-center gap-2 bg-gradient-to-br from-slate-700 to-slate-800">
          <span class="text-4xl opacity-30" aria-hidden="true">
            🖼️
          </span>
          <span class="text-xs text-slate-500 font-medium uppercase tracking-wider">
            No mockups yet
          </span>
        </div>
      )
    }
  </div>

  <div class="p-5">
    <div class="flex items-start justify-between gap-2 mb-1">
      <h3 class="font-semibold text-white group-hover:text-primary transition-colors leading-snug">
        {prototype.title}
      </h3>
      <span
        class={`text-xs font-medium px-2 py-0.5 rounded-full border shrink-0 ${statusStyle(prototype.status)}`}
      >
        <span class="sr-only">Status: </span>{prototype.status}
      </span>
    </div>
    <p class="text-sm text-slate-400 leading-relaxed line-clamp-2">{prototype.tagline}</p>
    <div class="flex items-center gap-1.5 mt-3 flex-wrap">
      {
        prototype.tags
          .slice(0, 3)
          .map((tag) => (
            <span class="text-xs px-2 py-0.5 bg-slate-700/80 rounded-full text-slate-400">
              {tag}
            </span>
          ))
      }
    </div>
  </div>
</a>
