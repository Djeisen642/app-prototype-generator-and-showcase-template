---
import type { Feature } from "../types";

type Props = Feature;

const { icon, title, description } = Astro.props;
---

<div
  class="bg-slate-800/50 border border-slate-700/50 rounded-xl p-6 hover:border-slate-600 transition-colors"
>
  <div class="text-3xl mb-3" aria-hidden="true">{icon}</div>
  <h3 class="font-semibold text-white mb-2">{title}</h3>
  <p class="text-sm text-slate-400 leading-relaxed">{description}</p>
</div>
