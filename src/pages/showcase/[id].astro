---
import Layout from "../../layouts/Layout.astro";
import { getPrototypeIndex } from "../../lib/prototypes";
import { statusStyle } from "../../lib/status";
import type { Prototype } from "../../types";

export function getStaticPaths() {
  const { prototypes } = getPrototypeIndex();
  return prototypes.map((prototype) => ({
    params: { id: prototype.id },
    props: { prototype },
  }));
}

interface Props {
  prototype: Prototype;
}

const { prototype } = Astro.props;
const { images, competitive, features } = prototype;
---

<Layout title={prototype.title}>
  <div class="max-w-4xl mx-auto px-4 py-12">
    {/* Header */}
    <div class="mb-8">
      <a href="/showcase" class="text-sm text-slate-500 hover:text-slate-300 transition-colors">
        ← Showcase
      </a>
      <div class="flex items-start justify-between gap-4 mt-3">
        <div>
          <h1 class="text-4xl font-extrabold text-white tracking-tight">{prototype.title}</h1>
          <p class="text-xl text-slate-300 mt-2">{prototype.tagline}</p>
        </div>
        <span
          class={`text-sm font-medium px-3 py-1 rounded-full border shrink-0 mt-1 ${statusStyle(prototype.status)}`}
        >
          {prototype.status}
        </span>
      </div>
      {
        prototype.tags.length > 0 && (
          <div class="flex gap-2 mt-3 flex-wrap">
            {prototype.tags.map((tag) => (
              <span class="text-xs px-2.5 py-1 bg-slate-800 border border-slate-700 rounded-full text-slate-400">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </div>

    {/* Image gallery */}
    {
      images.length > 0 ? (
        <div class="mb-10" data-gallery>
          <div class="rounded-xl overflow-hidden border border-slate-700 bg-slate-800">
            <img
              data-gallery-main
              src={images[0]}
              alt={`${prototype.title} mockup 1`}
              class="w-full object-cover"
            />
          </div>
          {images.length > 1 && (
            <div class="flex gap-2 mt-3">
              {images.map((src, i) => (
                <button
                  type="button"
                  data-gallery-thumb
                  data-src={src}
                  data-active={i === 0 ? "" : undefined}
                  class="flex-1 h-16 rounded-lg overflow-hidden border-2 transition-colors border-slate-700 opacity-60 hover:opacity-100 data-[active]:border-primary data-[active]:opacity-100"
                >
                  <img src={src} alt="" class="w-full h-full object-cover" />
                </button>
              ))}
            </div>
          )}
        </div>
      ) : (
        <div class="mb-10 h-48 rounded-xl border border-dashed border-slate-700 flex flex-col items-center justify-center gap-2 text-slate-600">
          <span class="text-4xl">🖼️</span>
          <span class="text-sm">No mockup images yet — ask your AI agent to generate them</span>
        </div>
      )
    }

    {/* Description */}
    <section class="mb-8">
      <h2 class="text-xl font-bold text-white mb-3">Overview</h2>
      <p class="text-slate-300 leading-relaxed">{prototype.description}</p>
    </section>

    {/* Problem */}
    {
      prototype.problem && (
        <section class="mb-8 bg-slate-800/40 border border-slate-700/60 rounded-xl p-6">
          <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500 mb-2">
            The Problem
          </h2>
          <p class="text-slate-300 leading-relaxed">{prototype.problem}</p>
        </section>
      )
    }

    {/* Target users */}
    {
      prototype.targetUsers && (
        <section class="mb-8">
          <h2 class="text-sm font-semibold uppercase tracking-widest text-slate-500 mb-2">
            Built For
          </h2>
          <p class="text-slate-300">{prototype.targetUsers}</p>
        </section>
      )
    }

    {/* Features */}
    {
      features && features.length > 0 && (
        <section class="mb-8">
          <h2 class="text-xl font-bold text-white mb-4">Key Features</h2>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {features.map((f) => (
              <div class="bg-slate-800/50 border border-slate-700/50 rounded-xl p-5">
                <div class="text-2xl mb-2">{f.icon}</div>
                <h3 class="font-semibold text-white mb-1">{f.title}</h3>
                <p class="text-sm text-slate-400 leading-relaxed">{f.description}</p>
              </div>
            ))}
          </div>
        </section>
      )
    }

    {/* Competitive */}
    {
      competitive && (
        <section class="mb-8">
          <h2 class="text-xl font-bold text-white mb-4">Why It Wins</h2>
          {competitive.competitors && competitive.competitors.length > 0 && (
            <div class="flex gap-2 mb-4 flex-wrap">
              <span class="text-sm text-slate-500 mr-1 self-center">Better than:</span>
              {competitive.competitors.map((c) => (
                <span class="text-sm px-3 py-1 bg-red-900/20 border border-red-800/30 rounded-full text-red-300">
                  {c}
                </span>
              ))}
            </div>
          )}
          {competitive.advantages && competitive.advantages.length > 0 && (
            <ul class="space-y-2">
              {competitive.advantages.map((adv) => (
                <li class="flex items-start gap-3 text-slate-300">
                  <span class="text-green-400 mt-0.5 shrink-0">✓</span>
                  {adv}
                </li>
              ))}
            </ul>
          )}
        </section>
      )
    }

    {/* HTML Mockup */}
    {
      prototype.htmlFile && (
        <section class="mt-10 border-t border-slate-800 pt-8">
          <details class="group">
            <summary class="flex items-center gap-2 text-sm font-medium text-slate-300 hover:text-white transition-colors cursor-pointer list-none [&::-webkit-details-marker]:hidden">
              <span class="transition-transform group-open:rotate-90">▶</span>
              <span class="group-open:hidden">View Interactive Mockup</span>
              <span class="hidden group-open:inline">Hide Interactive Mockup</span>
            </summary>
            <div class="mt-4 rounded-xl overflow-hidden border border-slate-700">
              <iframe
                src={prototype.htmlFile}
                class="w-full bg-white"
                style="height: 600px"
                title={`${prototype.title} mockup`}
                loading="lazy"
                sandbox="allow-scripts allow-same-origin"
              />
            </div>
          </details>
        </section>
      )
    }
  </div>
</Layout>

<script>
  // Tiny gallery island: swap the main image when a thumbnail is clicked.
  // Vanilla DOM — no framework runtime ships to the browser.
  document.querySelectorAll<HTMLElement>("[data-gallery]").forEach((gallery) => {
    const main = gallery.querySelector<HTMLImageElement>("[data-gallery-main]");
    const thumbs = gallery.querySelectorAll<HTMLButtonElement>("[data-gallery-thumb]");
    thumbs.forEach((thumb) => {
      thumb.addEventListener("click", () => {
        const src = thumb.dataset.src;
        if (main && src) main.src = src;
        thumbs.forEach((t) => t.removeAttribute("data-active"));
        thumb.setAttribute("data-active", "");
      });
    });
  });
</script>
